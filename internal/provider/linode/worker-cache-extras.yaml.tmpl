#cloud-config
# Worker cache-extras fragment. cloud-init merges this with the base
# worker user-data the orchestrator rendered.
#
# FJB-13: zot is a scratch registry workers address explicitly at
# cache.fjb.internal:5000. This fragment only ships CA trust +
# hostname resolution — workers know about zot only; nothing
# intercepts pulls of any other registry. Push to the canonical
# registry (Forgejo etc.) goes direct from the worker.
#
# merge_how is required because cloud-init's default merge strategy
# REPLACES lists across multipart parts — without this directive
# write_files and runcmd from this fragment would clobber the base
# bootstrap's lists (notably its SSH host-key install, which the
# orchestrator's dispatcher pins against). The settings below
# explicitly append both lists; dicts are recursive-no-replace so
# string scalars don't get accidentally overwritten either.
merge_how:
  - name: list
    settings: [append]
  - name: dict
    settings: [no_replace, recurse_list]
  - name: str
    settings: [append]
# Two things are added:
#  1. The fjb-managed CA, so workers trust the cache's TLS cert when
#     they `docker push/pull cache.fjb.internal:5000/...`.
#  2. An /etc/hosts entry mapping the cache hostname to its VPC IP
#     (no DNS dependency — workers reach the cache by IP via the
#     hosts-file lookup over the VPC NIC).
write_files:
  - path: /usr/local/share/ca-certificates/fjb-cache.crt
    permissions: '0644'
    content: |
{{.CACertPEM | indent 6}}
  - path: /etc/hosts
    append: true
    content: |
      {{.CacheIP}} {{.CacheHost}}
runcmd:
  - update-ca-certificates
