#cloud-config
# Worker bootstrap for fj-bellows. Installs Docker and the forgejo-runner
# binary, then signals readiness. It deliberately holds NO Forgejo credentials:
# the orchestrator registers an ephemeral runner per job and delivers the
# one-shot token over SSH at dispatch time.
package_update: true
packages:
  - docker.io
  - curl
  - ca-certificates
{{- if .FJBAgentDownloadURL}}
# fjbagent (FJB-94) — runs as the unprivileged `fjb` system user. The token
# below is the per-deployment shared secret; the orchestrator presents it on
# the Authorization header for every Connect RPC. WG already encrypts and
# authenticates the orchestrator↔cache leg, and the cache↔worker leg is on
# the private VPC subnet, so plain HTTP/2 cleartext is acceptable.
groups:
  - fjb
users:
  - name: fjb
    system: true
    no_create_home: true
    shell: /usr/sbin/nologin
    primary_group: fjb
write_files:
  - path: /etc/fjbagent/auth.token
    permissions: '0600'
    owner: 'fjb:fjb'
    content: |
      {{.FJBAgentToken}}
  - path: /etc/default/fjbagent
    permissions: '0644'
    content: |
      # Resolved by cloud-init at boot from the VPC IP cloud-init exposes
      # via instance-data; the orchestrator dials this address. Bound to
      # 0.0.0.0 so workers don't need to know their own VPC IP upfront —
      # the cache-gateway routing in FJB-54 makes the VPC subnet the only
      # reachable surface, and the WG ACL further constrains what can
      # land on :9001.
      FJBAGENT_LISTEN=0.0.0.0:{{.FJBAgentListenPort}}
  - path: /etc/systemd/system/fjbagent.service
    permissions: '0644'
    content: |
{{.FJBAgentServiceUnit | indent 6}}
{{- end}}
runcmd:
  - systemctl enable --now docker
{{- if .HostPrivateKey}}
  # The orchestrator generated this ed25519 host key and pre-pinned its public
  # half, so the dispatcher verifies the worker on the very first SSH dial. The
  # PEM is base64-encoded here so it survives the YAML/shell layers without
  # whitespace mangling.
  - |
    set -eu
    install -m 0600 /dev/null /etc/ssh/ssh_host_ed25519_key
    printf '%s' '{{.HostPrivateKey | b64enc}}' | base64 -d > /etc/ssh/ssh_host_ed25519_key
    chmod 0600 /etc/ssh/ssh_host_ed25519_key
    ssh-keygen -y -f /etc/ssh/ssh_host_ed25519_key > /etc/ssh/ssh_host_ed25519_key.pub
    chmod 0644 /etc/ssh/ssh_host_ed25519_key.pub
    mkdir -p /etc/ssh/sshd_config.d
    printf 'HostKey /etc/ssh/ssh_host_ed25519_key\n' > /etc/ssh/sshd_config.d/10-fj-bellows-hostkey.conf
    systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || systemctl restart sshd 2>/dev/null || systemctl restart ssh
{{- end}}
  - |
    set -eu
    arch="$(uname -m)"
    case "$arch" in
      x86_64) rarch=amd64 ;;
      aarch64|arm64) rarch=arm64 ;;
      *) echo "unsupported arch: $arch" >&2; exit 1 ;;
    esac
    url="https://code.forgejo.org/forgejo/runner/releases/download/v{{.RunnerVersion}}/forgejo-runner-{{.RunnerVersion}}-linux-${rarch}"
    curl -fsSL -o /usr/local/bin/forgejo-runner "$url"
    chmod +x /usr/local/bin/forgejo-runner
{{- if .FJBAgentDownloadURL}}
  - |
    set -eu
    arch="$(uname -m)"
    case "$arch" in
      x86_64) rarch=amd64 ;;
      aarch64|arm64) rarch=arm64 ;;
      *) echo "unsupported arch: $arch" >&2; exit 1 ;;
    esac
    url="{{.FJBAgentDownloadURL}}"
    curl -fsSL -o /usr/local/bin/fjbagent "$url"
    chmod +x /usr/local/bin/fjbagent
  - systemctl daemon-reload
  - systemctl enable --now fjbagent
{{- end}}
  - touch {{.ReadyFile}}
